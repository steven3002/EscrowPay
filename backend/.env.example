# EscrowPay backend configuration.
#
# Copy to `.env` and fill in as needed. The API loads `.env` on boot; real
# environment variables always take precedence over this file. Everything here
# has a development-safe default except the production secrets — the app runs
# out of the box with no .env at all, on the mock gateway.

# ── Core ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://escrowpay:escrowpay_dev@localhost:5433/escrowpay
LISTEN_ADDR=:8080

# Secrets. Unset in development falls back to insecure built-in values (the app
# logs a warning). Set to long random strings in any real deployment.
LINK_TOKEN_SECRET=
RELEASE_CODE_SECRET=

# ── Policy durations ──────────────────────────────────────────────────────
FUNDING_LINK_TTL_HOURS=72
GRACE_HOURS=24
EVIDENCE_CAPTURE_WINDOW_MINUTES=60

# ── Settlement sweeper ────────────────────────────────────────────────────
SWEEPER_ENABLED=true
SWEEPER_INTERVAL_SECONDS=60

# ── Evidence storage ──────────────────────────────────────────────────────
EVIDENCE_DIR=./data/evidence
EVIDENCE_MAX_MB=25

# ── Sessions & transport hardening ────────────────────────────────────────
SESSION_TTL_HOURS=720
COOKIE_SECURE=false        # true wherever HTTPS terminates
TRUST_PROXY=true           # key rate limits on X-Forwarded-For (app sits behind the Next proxy)
RATE_LIMIT_ENABLED=true

# SANDBOX_MODE gates demo affordances (demo login). Keep true for local demos.
SANDBOX_MODE=true

# ── Google sign-in (optional) ─────────────────────────────────────────────
# Sign-in with Google is enabled only when all three are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
# GOOGLE_ISSUER=            # test override only

# ── Payment gateway ───────────────────────────────────────────────────────
# mock  — no money moves; funding via the sandbox shortcut button (default)
# nomba — real bank rails (sandbox or production per NOMBA_BASE_URL)
GATEWAY_PROVIDER=mock

# Keep the one-click funding shortcut available. Defaults to true on the mock
# gateway and false on nomba; set true to keep it as a demo fallback on rails.
# SIMULATE_FUNDING_ENABLED=true

# --- Nomba (only when GATEWAY_PROVIDER=nomba) ---
NOMBA_BASE_URL=https://sandbox.nomba.com
# Credentials also accept the dashboard export names TEST_CREDENTIALS_CLIENT_ID/SECRET,
# PARENT_ACCOUNT_ID and SUB_ACCOUNT_ID as fallbacks.
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_PARENT_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=

# Webhook signature key from Dashboard → Developer → Webhook Setup. Unset leaves
# the webhook endpoint unmounted, so funding cannot confirm on real rails.
NOMBA_SIGNATURE_KEY=

# App origin the hosted checkout redirects back to, and the receipt email used
# when a buyer account has none on file.
PUBLIC_BASE_URL=http://localhost:3000
NOMBA_FALLBACK_CUSTOMER_EMAIL=buyer@escrowpay.example

# Default transfer beneficiaries for payouts/refunds until participants carry
# their own payout accounts.
NOMBA_PAYOUT_ACCOUNT_NUMBER=
NOMBA_PAYOUT_BANK_CODE=
NOMBA_PAYOUT_ACCOUNT_NAME=
NOMBA_REFUND_ACCOUNT_NUMBER=
NOMBA_REFUND_BANK_CODE=
NOMBA_REFUND_ACCOUNT_NAME=
